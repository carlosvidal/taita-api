# Database
DATABASE_URL="postgresql://username:password@hostname:port/database_name"

# JWT Secret (genera uno nuevo con: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-here"
#JWT_SECRET="QjyOw0U+o/3nd5T64D7dgi+GDuILQ4+ia6hu3thAyGY="

# App Configuration
NODE_ENV="development"
PORT=3001
CORS_ORIGIN="http://localhost:3000,https://taita.blog,https://*.taita.blog"

# Email Configuration (MailerSend)
MAILERSEND_API_TOKEN="your-mailersend-api-token"
FROM_EMAIL="noreply@taita.blog"
FROM_NAME="Taita Blog"

# MercadoPago (si usas pagos)
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token"
MERCADOPAGO_PUBLIC_KEY="your-mercadopago-public-key"

# File Upload Configuration
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="5242880"

# Domain Configuration
MAIN_DOMAIN="taita.blog"
API_URL="https://taita-api.onrender.com"

# Cloudinary Configuration (legacy — only needed for deleting old images)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Cloudflare R2 Configuration
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="taita-media"
R2_PUBLIC_URL="https://media.taita.blog"